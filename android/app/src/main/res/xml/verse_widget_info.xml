<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget'ın sistem tarafında nasıl davranacağını tanımlar: minimum boyut,
  ne sıklıkla otomatik güncelleneceği, kullanıcı ana ekrana eklerken
  göreceği önizleme.

  updatePeriodMillis="10800000" -> 3 saatte bir sistem tarafından otomatik
  yenileme dener (Android'in izin verdiği en sık aralıklardan biri —
  daha sık istenirse WorkManager ile ayrıca tetiklemek gerekir, bkz.
  main.dart'taki TODO(widget-refresh)).
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="250dp"
    android:minHeight="80dp"
    android:updatePeriodMillis="10800000"
    android:initialLayout="@layout/verse_widget"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewImage="@mipmap/ic_launcher" />