<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget kartının arkaplanı. Doküman: "Widget kullanıcının kendi
  fotoğrafının üstünde şeffaf yüzer" — bu yüzden tamamen opak değil,
  ama düz siyahtan farklı olarak sıcak, hafif kahve-altın tonlu bir
  degrade + ince altın kenarlık kullanıyoruz (uygulamadaki kart
  stiliyle aynı dil: koyu cam + gold-bright/10 vurgu).
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Ana kart: diagonal koyu-sıcak degrade -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <gradient
                android:type="linear"
                android:angle="315"
                android:startColor="#E6241C12"
                android:centerColor="#E61F1B13"
                android:endColor="#E6120F0A" />
        </shape>
    </item>

    <!-- İnce altın kenarlık (uygulamadaki border-brand-gold-bright/10 karşılığı) -->
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="24dp" />
            <stroke
                android:width="1dp"
                android:color="#26C9A227" />
        </shape>
    </item>

</layer-list>